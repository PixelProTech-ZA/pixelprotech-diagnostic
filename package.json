{
  "name": "pixelprotech-diagnostic",
  "version": "1.0.0",
  "description": "PixelProTech PC Diagnostic Tool — Windows & Linux",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:linux": "electron-builder --linux AppImage",
    "build:all": "electron-builder --win portable --linux AppImage"
  },
  "build": {
    "appId": "co.za.pixelprotech.diagnostic",
    "productName": "PixelProTech Diagnostic",
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "portable": {
      "artifactName": "PixelProTech-Diagnostic-Windows.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
